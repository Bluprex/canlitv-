rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Admin yetkisi kontrol fonksiyonu
    function isAdmin() {
      return request.auth != null && (
        request.auth.token.email == 'admin@gostasoftware.com' || 
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    // Kanallar: Herkes okuyabilir, SADECE admin yazabilir
    match /channels/{channelId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Kullanıcılar: Sadece kendileri okuyup yazabilir
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Admin Listesi: Genel okuma açık, sadece ana admin yazabilir
    match /admins/{adminId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.email == 'admin@gostasoftware.com';
    }

    // Raporlar: Herkes rapor oluşturabilir (yazma), SADECE admin okuyabilir ve silebilir
    match /reports/{reportId} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }
  }
}
